{
  "name": "effect-claude-primitives",
  "version": "1.0.0",
  "description": "Drop-in Claude primitives for Effect-TS projects - 700+ patterns as AI-readable rules",
  "type": "module",
  "bin": {
    "effect-claude-primitives": "./cli/dist/install.js"
  },
  "files": [
    "rules/",
    "skills/",
    "templates/",
    "cli/dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "effect",
    "effect-ts",
    "claude",
    "cursor",
    "copilot",
    "ai-coding",
    "coding-rules",
    "typescript",
    "functional-programming"
  ],
  "dependencies": {
    "@effect/cli": "0.73.2",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "effect": "3.19.19"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "bun build cli/src/install.ts --outdir cli/dist --target bun --format esm && chmod +x cli/dist/install.js",
    "build:tsc": "tsc",
    "clean": "rm -rf cli/dist",
    "prepublishOnly": "bun run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stiproot/effect-claude-primitives.git"
  },
  "bugs": {
    "url": "https://github.com/stiproot/effect-claude-primitives/issues"
  },
  "homepage": "https://github.com/stiproot/effect-claude-primitives#readme",
  "author": "Effect Patterns Community",
  "engines": {
    "bun": ">=1.0.0"
  }
}
